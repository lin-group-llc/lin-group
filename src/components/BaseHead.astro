---
import "../styles/global.css";
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_URL,
  SITE_AUTHOR,
} from "../consts";

const {
  title,
  description,
  ogType = "website",
  canonical,
  relPrev,
  relNext,
} = Astro.props as {
  title: string;
  description?: string;
  ogType?: string;
  canonical?: string;
  relPrev?: string;
  relNext?: string;
};

const resolveAbsoluteURL = (maybeRelative?: string) => {
  if (!maybeRelative) return undefined;
  if (maybeRelative.startsWith("http")) return maybeRelative;
  try {
    return new URL(maybeRelative, SITE_URL).toString();
  } catch {
    return undefined;
  }
};

const canonicalURL =
  resolveAbsoluteURL(canonical) ?? new URL(Astro.url.pathname, SITE_URL).toString();
const prevURL = resolveAbsoluteURL(relPrev);
const nextURL = resolveAbsoluteURL(relNext);

const metaDescription = description || SITE_DESCRIPTION;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://lingroup.us/#organization",
  name: "Lin Group",
  url: "https://lingroup.us",
  email: "contact@lingroup.us",
  sameAs: ["https://leonlins.com"],
  founder: { "@id": "https://leonlins.com/#person" },
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://leonlins.com/#person",
  name: "Leon Lin",
  url: "https://leonlins.com",
  sameAs: ["https://leonlins.com"],
  founderOf: { "@id": "https://lingroup.us/#organization" },
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="light dark" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={metaDescription} />
<meta name="author" content={SITE_AUTHOR} />
<meta name="robots" content="index, follow" />

<link rel="canonical" href={canonicalURL} />
{prevURL && <link rel="prev" href={prevURL} />}
{nextURL && <link rel="next" href={nextURL} />}

<link rel="shortcut icon" href="/favicon.png" />
<link rel="icon" href="/favicon.png" type="image/png" />

<meta property="og:type" content={ogType} />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={SITE_TITLE} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={new URL("/og.png", SITE_URL).toString()} />

<script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
