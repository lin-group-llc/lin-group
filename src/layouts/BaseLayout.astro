---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';

const {
  title,
  description,
  image,
  pubDate,
  updatedDate,
  authorName,
  ogType,
  tags,
  canonical,
  relPrev,
  relNext,
} = Astro.props;

const normalizedTitle = title?.trim();
const finalTitle = !normalizedTitle || normalizedTitle === SITE_TITLE
  ? SITE_TITLE
  : normalizedTitle.includes('—') || normalizedTitle.includes('|')
    ? normalizedTitle
    : `${normalizedTitle} — ${SITE_TITLE}`;

const GA_ID = import.meta.env.PUBLIC_GA_ID;
const isProd = import.meta.env.PROD;
---

<html lang="en">
  <head>
    <BaseHead
      title={finalTitle}
      description={description}
      image={image}
      pubDate={pubDate}
      updatedDate={updatedDate}
      authorName={authorName}
      ogType={ogType}
      tags={tags}
      canonical={canonical}
      relPrev={relPrev}
      relNext={relNext}
    />

    {
      isProd && GA_ID && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
          />
          <script
            is:inline
            set:html={`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '${GA_ID}', { anonymize_ip: true });
          `}
          />
        </>
      )
    }
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <main class="page-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-main {
    max-width: var(--max-content-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    min-height: calc(100vh - 8.25rem);
  }
</style>
