---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Lin Group"
  description="Private investment and holding company."
  canonical="https://lingroup.us"
>
  <section class="home">
    <h1>Lin Group</h1>
    <p class="descriptor">Private investment and holding company.</p>
    <p>
      Lin Group engages in selective investments and related business activities
      across businesses, technology, and other assets.
    </p>
    <p class="contact"><a href="mailto:contact@lingroup.us">contact@lingroup.us</a></p>
  </section>
</BaseLayout>

<style>
  .home {
    max-width: 41rem;
    margin: clamp(5rem, 13vh, 9rem) auto clamp(4.5rem, 11vh, 7.5rem);
    text-align: left;
  }

  h1 {
    margin-bottom: 0.85rem;
    letter-spacing: 0.01em;
    font-weight: 650;
  }

  .descriptor {
    color: var(--color-text-muted);
    font-size: 1.03rem;
    line-height: 1.6;
    margin-bottom: 1.7rem;
  }

  .home p {
    max-width: 39rem;
  }

  .contact {
    margin-top: 2.1rem;
    margin-bottom: 0;
    font-size: var(--text-sm);
  }

  .contact a {
    color: var(--color-text);
  }
</style>
