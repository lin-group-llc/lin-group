---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Lin Group"
  description="Private holding and investment company."
>
  <section class="home">
    <h1>Lin Group</h1>
    <p class="descriptor">Private holding and investment company.</p>
    <p>
      Lin Group engages in selective investments and related business activities
      across businesses, technology, and other assets.
    </p>
    <p>For inquiries: <a href="mailto:contact@lingroup.us">contact@lingroup.us</a></p>
  </section>
</BaseLayout>

<style>
  .home {
    max-width: 40rem;
    margin: var(--space-xl) auto;
  }

  .descriptor {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }
</style>
